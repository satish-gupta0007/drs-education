# ─── MongoDB ────────────────────────────────────────────────────────────────
# Local MongoDB
MONGODB_URI="mongodb://localhost:27017/drs_education"

# MongoDB Atlas (cloud - recommended for production)
# MONGODB_URI="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/drs_education?retryWrites=true&w=majority"

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="change-this-to-a-different-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── AWS S3 (optional – for video/PDF storage) ───────────────────────────────
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="drs-education-media"
